\frametitle{Пример программы на C}
		
		Программа для вывода двоичного представления числа:
		
		\vspace{0.2cm}
		
		\begin{lstlisting}
			#include <stdio.h>
			
			void printBinary(int n) {
				for (int i = 7; i >= 0; i--) {
					printf("%d", (n >> i) & 1);
				}
				printf("\n");
			}
			
			int main() {
				int number = 10;
				printf("Chislo %d: ", number);
				printBinary(number);
				return 0;
			}
		\end{lstlisting}
		
		
